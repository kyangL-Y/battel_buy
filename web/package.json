{
  "name": "battel-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "snapshot:market": "python -X utf8 ../tools/export_market_static_snapshot.py",
    "build": "vite build",
    "preview": "vite preview",
    "test:e2e": "node ./scripts/playwright-with-local-libs.mjs test",
    "test:e2e:mobile": "node ./scripts/playwright-with-local-libs.mjs test tests/mobile-regression.spec.ts",
    "test:e2e:headed": "node ./scripts/playwright-with-local-libs.mjs test --headed",
    "test:e2e:real": "npm run build && node ./scripts/playwright-with-local-libs.mjs test --config=playwright.real.config.ts"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "battel": "file:..",
    "echarts": "^5.5.1",
    "element-plus": "^2.7.8",
    "vue": "^3.4.31",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@vitejs/plugin-vue": "^5.0.5",
    "typescript": "^5.5.4",
    "vite": "^5.3.4"
  }
}
